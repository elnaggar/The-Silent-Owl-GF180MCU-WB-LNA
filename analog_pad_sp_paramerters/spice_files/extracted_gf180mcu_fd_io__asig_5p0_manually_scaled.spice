***************************************************************************************************
* --- Core Power Clamp Diodes (40 um^2) ---
* Note: Magic correctly extracts explicit capacitors in Farads. No math scaling applied.
***************************************************************************************************
D8  DVSS DVDD diode_nd2ps_06v0 pj=82e-6 area=40e-12
D9  DVSS DVDD diode_nd2ps_06v0 pj=82e-6 area=40e-12
D10 DVSS DVDD diode_nd2ps_06v0 pj=82e-6 area=40e-12
D11 DVSS DVDD diode_nd2ps_06v0 pj=82e-6 area=40e-12

***************************************************************************************************
* --- Parasitic Routing Capacitance ---
* Note: Magic correctly extracts explicit capacitors in Farads. No math scaling applied.
***************************************************************************************************
C0 VDD  DVDD   48.08535f
C1 VDD  ASIG5V 21.91101f
C2 DVDD ASIG5V 0.62445p
C3 VDD  DVSS   50.97537f
C4 DVDD DVSS   1.55036p
C5 DVSS ASIG5V 0.47973p

***************************************************************************************************
* --- Substrate Parasitics (Topological Fix) ---
* Note: Replaced floating node 'GF_NI_ASIG_5P0_BASE_0/comp018green_esd_hbm_0/VSUBS' with global pin 'VSS'.
***************************************************************************************************
C6 VDD    VSS 47.06129f
C7 ASIG5V VSS 0.27637p
C8 DVSS   VSS 0.20258p
C9 DVDD   VSS 0.35736p

.ENDS
