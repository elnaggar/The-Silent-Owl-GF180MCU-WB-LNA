***************************************************************************************************
***************************************************************************************************
* SSCS-Chipathon 2026, Team A38: The Night Owl
* File Version: Ver 1.0
* editor: Ahmed M. Elnaggar, elnaggar@email.sc.edu
* SSCS-Chipathon 2026, Team A38: The Silent Owl
* github: @elnaggar
* Magic Base Resolution (lambda) = 5nm (5e-9 m)
* Linear Scale Factor = 5e-9 m
* Area Scale Factor = (5e-9 m)^2 = 25e-18 m^2
***************************************************************************************************
* This file is a corrected version of gf180mcuD_fd_io__asig_5p0.spice magic layout extraction due 
* to failure of spice to apply the scaling factor option from magic extraction: {.option scale=5n}
*
*Also, this fix the unmatched pin arragement of the analog pad symbol and the subcircuit wrapper
***************************************************************************************************
***************************************************************************************************

***************************************************************************************************
* Subciruit wrapper for the extracted spice
***************************************************************************************************
*.SUBCKT gf180mcu_fd_io__asig_5p0 ASIG5V DVDD DVSS VDD VSS 
.SUBCKT gf180mcu_fd_io__asig_5p0 DVDD ASIG5V DVSS VDD VSS

***************************************************************************************************
* --- Signal ESD Diodes (150 um^2) ---
* Mathematical correction: pj = 21200 * 5e-9 = 106e-6 m | area = 6,000,000 * 25e-18 = 150e-12 m^2
***************************************************************************************************
D0 DVSS   ASIG5V diode_nd2ps_06v0 pj=106e-6 area=150e-12
D1 DVSS   ASIG5V diode_nd2ps_06v0 pj=106e-6 area=150e-12
D2 ASIG5V DVDD   diode_pd2nw_06v0 pj=106e-6 area=150e-12
D3 DVSS   ASIG5V diode_nd2ps_06v0 pj=106e-6 area=150e-12
D4 DVSS   ASIG5V diode_nd2ps_06v0 pj=106e-6 area=150e-12
D5 ASIG5V DVDD   diode_pd2nw_06v0 pj=106e-6 area=150e-12
D6 ASIG5V DVDD   diode_pd2nw_06v0 pj=106e-6 area=150e-12
D7 ASIG5V DVDD   diode_pd2nw_06v0 pj=106e-6 area=150e-12

***************************************************************************************************
* --- MOSCAPs (15 um x 15 um) ---
* Mathematical correction: c_width = 3000 * 5e-9 = 15e-6 m | c_length = 3000 * 5e-9 = 15e-6 m
***************************************************************************************************
X0  DVDD DVSS cap_nmos_06v0 c_width=15e-6 c_length=15e-6
X1  DVDD DVSS cap_nmos_06v0 c_width=15e-6 c_length=15e-6
X2  DVDD DVSS cap_nmos_06v0 c_width=15e-6 c_length=15e-6
